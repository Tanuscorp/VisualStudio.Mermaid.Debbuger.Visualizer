<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="12" MinWidth="460">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />   <!-- Status / title -->
      <RowDefinition Height="*" />      <!-- Rendered image -->
      <RowDefinition Height="Auto" />   <!-- Source code expander -->
      <RowDefinition Height="Auto" />   <!-- Action buttons -->
    </Grid.RowDefinitions>

    <Grid.Resources>
      <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Grid.Resources>

    <!-- Status bar -->
    <TextBlock Grid.Row="0"
               Text="{Binding StatusMessage}"
               FontWeight="SemiBold"
               FontSize="13"
               TextWrapping="Wrap"
               Margin="0,0,0,10" />

    <!-- Rendered PNG image (visible when HasRenderedImage = true) -->
    <Border Grid.Row="1"
            Background="White"
            CornerRadius="6"
            Padding="16"
            Margin="0,0,0,10"
            Visibility="{Binding HasRenderedImage, Converter={StaticResource BoolToVisibility}}">
      <Image Source="{Binding DiagramImageUri}"
             Stretch="Uniform"
             MaxHeight="480"
             HorizontalAlignment="Center" />
    </Border>

    <!-- Source code expander -->
    <Expander Grid.Row="2"
              Margin="0,0,0,10"
              Visibility="{Binding HasMermaidContent, Converter={StaticResource BoolToVisibility}}">
      <Expander.Header>
        <TextBlock Text="Mermaid source" FontSize="12" />
      </Expander.Header>
      <TextBox Text="{Binding MermaidSource}"
               IsReadOnly="True"
               FontFamily="Consolas"
               FontSize="11"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Auto"
               MaxHeight="160"
               MinWidth="400"
               Margin="0,6,0,0" />
    </Expander>

    <!-- Action buttons -->
    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                Visibility="{Binding HasMermaidContent, Converter={StaticResource BoolToVisibility}}">
      <Button Content="🌐 Open in Browser"
              Command="{Binding OpenInBrowserCommand}"
              Padding="10,4"
              Margin="0,0,8,0" />
      <Button Content="📋 Copy Source"
              Command="{Binding CopySourceCommand}"
              Padding="10,4" />
    </StackPanel>
  </Grid>
</DataTemplate>
